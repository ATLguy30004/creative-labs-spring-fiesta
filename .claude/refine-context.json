{
  "project": "Creative Labs Spring Fiesta Invite",
  "direction": {
    "number": 3,
    "name": "Noche de Fiesta",
    "page_file": "src/pages/direction-3-noche-de-fiesta.astro",
    "components_dir": "src/components/direction-3/",
    "components_in_order": [
      "Nav.astro",
      "Hero.astro",
      "EventDetails.astro",
      "FreeTickets.astro",
      "FoodActivities.astro",
      "LocationParking.astro",
      "PartnerBanner.astro",
      "Footer.astro"
    ]
  },

  "dev_server": {
    "command": "npm run dev -- --port 4322 --host",
    "url": "http://localhost:4322/direction-3-noche-de-fiesta",
    "reveal_scroll_animations": "document.querySelectorAll('.scroll-reveal').forEach(el => el.classList.add('revealed'));"
  },

  "brief_files": [
    ".new-site/brief.md",
    ".new-site/directions.json"
  ],

  "logos": {
    "elote_king": "Content/eloteking-logo.png",
    "creative_labs_source": "Content/Creative learning logo copy.pdf",
    "creative_labs_note": "Convert the PDF to PNG before use. Use Bash: `magick 'Content/Creative learning logo copy.pdf' -density 300 public/logos/creative-labs-logo.png` — if ImageMagick not available, use Python Pillow or flag to Fahim."
  },

  "hero_video": {
    "instruction": "Compile a hero highlight reel from the highest-energy moments across the two source videos. Use ffmpeg to concatenate scenes. Output to public/videos/hero-highlight.mp4.",
    "source_videos": {
      "bull_original": "Content/Guy riding the bull and falling.mp4",
      "girls_captioned": "Content/video2_girls_captioned.mp4"
    },
    "pre_cut_scenes": {
      "scene_01_mount": "Content/_enhanced/creative-labs-spring-fiesta/scene_01_mount.mp4",
      "scene_02_riding": "Content/_enhanced/creative-labs-spring-fiesta/scene_02_riding.mp4",
      "scene_03_fall": "Content/_enhanced/creative-labs-spring-fiesta/scene_03_full_fall.mp4",
      "hero_graded": "Content/_enhanced/creative-labs-spring-fiesta/hero_bull_graded.mp4",
      "food_vibes": "Content/_enhanced/creative-labs-spring-fiesta/event_food_vibes.mp4"
    },
    "recommended_sequence": "scene_01_mount → scene_02_riding → scene_03_fall (the viral fall is the highest-energy moment — end on it)",
    "ffmpeg_command": "ffmpeg -i Content/_enhanced/creative-labs-spring-fiesta/scene_01_mount.mp4 -i Content/_enhanced/creative-labs-spring-fiesta/scene_02_riding.mp4 -i Content/_enhanced/creative-labs-spring-fiesta/scene_03_full_fall.mp4 -filter_complex '[0:v][1:v][2:v]concat=n=3:v=1[outv]' -map '[outv]' -c:v libx264 -crf 23 -preset fast public/videos/hero-highlight.mp4"
  },

