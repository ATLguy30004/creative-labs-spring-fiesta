---
/**
 * LocationParking — Address, parking info, map placeholder.
 * Green accent background section for visual rhythm contrast.
 */
---

<section class="location-section" id="location">
  <!-- Diagonal top edge -->
  <div class="loc-edge-top" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" fill="var(--color-brand-bg)">
      <path d="M0,0 L1440,0 L1440,30 Q1200,60 960,30 Q720,0 480,30 Q240,60 0,30 Z"/>
    </svg>
  </div>

  <div class="loc-inner">
    <div class="loc-content scroll-reveal" data-reveal="slide-up">
      <h2 class="loc-eyebrow">Find Us</h2>
      <h3 class="loc-heading">Creative Labs Center</h3>
      <p class="loc-address">6180 Atlanta Highway<br/>Alpharetta, GA 30004</p>

      <div class="loc-parking-pill">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-2"/><circle cx="5.5" cy="18" r="2"/><circle cx="18.5" cy="18" r="2"/></svg>
        Parking available on-site
      </div>
    </div>

    <!-- Map placeholder -->
    <div class="loc-map scroll-reveal" data-reveal="scale" style="--reveal-delay: 200ms;">
      <div class="loc-map-placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        <span class="loc-map-label">6180 Atlanta Highway, Alpharetta</span>
        <a
          href="https://www.google.com/maps/search/?api=1&query=6180+Atlanta+Highway+Alpharetta+GA+30004"
          target="_blank"
          rel="noopener noreferrer"
          class="loc-map-link"
        >
          Open in Google Maps
        </a>
      </div>
    </div>
  </div>

  <!-- Confetti dots on green -->
  <span class="loc-confetti loc-confetti--1" aria-hidden="true"></span>
  <span class="loc-confetti loc-confetti--2" aria-hidden="true"></span>
</section>

<style>
  @reference "../../styles/global.css";

  .location-section {
    position: relative;
    padding: 6rem 1.5rem 5rem;
    background: var(--color-brand-primary);
    color: white;
    overflow: hidden;
  }

  .loc-edge-top {
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    line-height: 0;
    z-index: 2;
  }
  .loc-edge-top svg { width: 100%; height: 60px; }

  .loc-inner {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .loc-content {
    position: relative;
    z-index: 2;
  }

  .loc-eyebrow {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0.5rem;
  }

  .loc-heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 2.8rem);
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
  }

  .loc-address {
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.9);
    margin-bottom: 1.5rem;
  }

  .loc-parking-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255,255,255,0.15);
    border: 2px solid rgba(255,255,255,0.25);
    padding: 0.55rem 1.3rem;
    border-radius: 100px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    color: white;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .loc-map {
    position: relative;
    z-index: 2;
  }

  .loc-map-placeholder {
    background: rgba(255,255,255,0.1);
    border: 2px dashed rgba(255,255,255,0.3);
    border-radius: 24px;
    padding: 3rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .loc-map-placeholder:hover {
    transform: scale(1.02);
  }

  .loc-map-label {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: rgba(255,255,255,0.8);
  }

  .loc-map-link {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-brand-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .loc-map-link:hover {
    color: white;
  }

  /* Confetti dots */
  .loc-confetti {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    animation: pulse-dot 3s ease-in-out infinite;
  }
  .loc-confetti--1 { width: 16px; height: 16px; background: rgba(255,208,36,0.3); top: 15%; right: 8%; animation-delay: 0.5s; }
  .loc-confetti--2 { width: 10px; height: 10px; background: rgba(255,255,255,0.2); bottom: 20%; left: 6%; animation-delay: 1.5s; }

  @keyframes pulse-dot {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.3); }
  }

  /* Scroll-reveal */
  .scroll-reveal {
    opacity: 0;
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }
  .scroll-reveal[data-reveal="slide-up"] { transform: translateY(40px); }
  .scroll-reveal[data-reveal="scale"] { transform: scale(0.9); }
  .scroll-reveal.revealed {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (max-width: 700px) {
    .loc-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }
    .loc-parking-pill {
      justify-content: center;
    }
  }
</style>
