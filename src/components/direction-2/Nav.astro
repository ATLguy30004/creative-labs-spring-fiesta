---
/**
 * Nav — Minimal, airy Creative Labs branding.
 * Scroll-responsive: transparent at top, frosted glass on scroll.
 * Botanical leaf accent beside logo text.
 */
---

<nav class="nav" id="garden-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="#" class="nav-brand" aria-label="Creative Labs Center">
      <!-- Inline leaf SVG as logo accent -->
      <svg class="nav-leaf" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path d="M8 28C8 28 6 16 16 8C26 16 24 28 24 28" fill="var(--color-brand-primary)" opacity="0.25"/>
        <path d="M16 8C16 8 12 18 16 28" stroke="var(--color-brand-primary)" stroke-width="1.5" fill="none"/>
        <path d="M16 14C18 13 22 14 22 14" stroke="var(--color-brand-primary)" stroke-width="1" fill="none" opacity="0.6"/>
        <path d="M16 18C14 17 10 18 10 18" stroke="var(--color-brand-primary)" stroke-width="1" fill="none" opacity="0.6"/>
      </svg>
      <span class="nav-brand-text">Creative Labs</span>
    </a>
    <span class="nav-event-badge">Spring Fiesta</span>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 1.5rem;
    transition: background 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                padding 0.3s ease;
  }

  .nav.scrolled {
    background: rgba(244, 255, 240, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 1px 20px rgba(30, 58, 30, 0.06);
    padding: 0.6rem 1.5rem;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-brand-text);
  }

  .nav-leaf {
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .nav-brand:hover .nav-leaf {
    transform: rotate(-12deg) scale(1.1);
  }

  .nav-brand-text {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .nav-event-badge {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-primary);
    background: rgba(113, 175, 71, 0.1);
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    border: 1px solid rgba(113, 175, 71, 0.2);
  }
</style>

<script>
  const nav = document.getElementById('garden-nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 40) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
