---
/**
 * FreeTickets — REBUILT. Dark bg with golden accents.
 * Photo-backed redeem cards. Bold typography. Visible disclaimer.
 */
---

<section class="free-tickets scroll-reveal" id="free-tickets" aria-label="Your free tickets">
  <!-- Geometric decorations -->
  <div class="tickets-geo" aria-hidden="true">
    <span class="geo-diamond geo-diamond--1"></span>
    <span class="geo-diamond geo-diamond--2"></span>
    <span class="geo-diamond geo-diamond--3"></span>
  </div>

  <div class="tickets-inner">
    <div class="vip-badge">
      <span class="diamond-dot" aria-hidden="true"></span>
      Enrolled Student Exclusive
      <span class="diamond-dot" aria-hidden="true"></span>
    </div>

    <h2 class="tickets-title">YOUR FREE<br>TICKETS</h2>

    <p class="tickets-hook">Each enrolled Creative Labs student receives</p>

    <div class="ticket-count-block">
      <span class="ticket-number">2</span>
      <span class="ticket-word">FREE<br>TICKETS</span>
    </div>

    <p class="tickets-choose">Choose your reward at the Elote King station:</p>

    <div class="redeem-options">
      <div class="redeem-card">
        <div class="redeem-photo">
          <img src="/images/popsicle_pink.png" alt="Pink popsicle treat from Elote King" loading="lazy" />
          <div class="redeem-photo-overlay"></div>
        </div>
        <div class="redeem-content">
          <span class="redeem-value">Popsicle</span>
          <span class="redeem-detail">from Elote King</span>
        </div>
      </div>

      <div class="redeem-or">
        <span class="or-line"></span>
        <span class="or-text">OR</span>
        <span class="or-line"></span>
      </div>

      <div class="redeem-card">
        <div class="redeem-photo">
          <img src="/images/rider_waving.jpg" alt="Rider waving on the mechanical bull at the Spring Fiesta" loading="lazy" />
          <div class="redeem-photo-overlay"></div>
        </div>
        <div class="redeem-content">
          <span class="redeem-value">Mechanical Bull Ride</span>
          <span class="redeem-detail">at Elote King</span>
        </div>
      </div>
    </div>

    <p class="tickets-disclaimer">Tickets redeemable at the Elote King station during the event. Each enrolled student receives 2 tickets — one for each reward, or two of the same. Present your student confirmation at check-in.</p>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .free-tickets {
    position: relative;
    padding: 6rem 1.5rem;
    background: var(--color-brand-bg);
    overflow: hidden;
    border-top: 1px solid rgba(255, 208, 36, 0.15);
    border-bottom: 1px solid rgba(255, 208, 36, 0.15);
  }

  .tickets-inner {
    position: relative;
    z-index: 2;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  /* ── VIP Badge ── */
  .vip-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-brand-primary);
    padding: 0.5rem 1.4rem;
    border: 1px solid rgba(255, 208, 36, 0.3);
    margin-bottom: 2rem;
  }

  .diamond-dot {
    width: 6px;
    height: 6px;
    background: var(--color-brand-primary);
    transform: rotate(45deg);
    display: inline-block;
  }

  /* ── Title ── */
  .tickets-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(3.5rem, 12vw, 7rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: white;
    margin: 0 0 1.5rem;
    text-shadow: 0 0 60px rgba(255, 208, 36, 0.15);
  }

  .tickets-hook {
    font-family: var(--font-body);
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  /* ── Giant ticket number ── */
  .ticket-count-block {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .ticket-number {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(6rem, 18vw, 10rem);
    color: var(--color-brand-primary);
    line-height: 1;
    text-shadow: 0 0 80px rgba(255, 208, 36, 0.3), 0 0 160px rgba(255, 208, 36, 0.1);
    animation: number-glow 3s ease-in-out infinite alternate;
  }

  @keyframes number-glow {
    0% { text-shadow: 0 0 40px rgba(255, 208, 36, 0.2); }
    100% { text-shadow: 0 0 80px rgba(255, 208, 36, 0.4), 0 0 140px rgba(255, 208, 36, 0.15); }
  }

  .ticket-word {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2rem, 6vw, 3.5rem);
    color: white;
    letter-spacing: 0.05em;
    text-align: left;
    line-height: 1.05;
  }

  .tickets-choose {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 2rem;
    font-weight: 500;
  }

  /* ── Redeem options ── */
  .redeem-options {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .redeem-card {
    border: 1px solid rgba(255, 208, 36, 0.2);
    border-radius: 16px;
    overflow: hidden;
    flex: 1;
    max-width: 340px;
    transition: all 0.3s ease;
    position: relative;
    background: var(--color-brand-surface);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .redeem-card:hover {
    border-color: rgba(255, 208, 36, 0.5);
    box-shadow: 0 12px 48px rgba(255, 208, 36, 0.1), 0 8px 32px rgba(0, 0, 0, 0.4);
    transform: translateY(-6px);
  }

  .redeem-photo {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .redeem-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .redeem-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, var(--color-brand-surface) 100%);
  }

  .redeem-content {
    padding: 1.25rem 1.5rem 1.75rem;
    text-align: center;
  }

  .redeem-value {
    display: block;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1.6rem;
    color: white;
    letter-spacing: -0.01em;
    margin-bottom: 0.3rem;
  }

  .redeem-detail {
    display: block;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .redeem-or {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-shrink: 0;
    align-self: center;
  }

  .or-text {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1rem;
    color: var(--color-brand-primary);
    letter-spacing: 0.15em;
  }

  .or-line {
    width: 1px;
    height: 32px;
    background: linear-gradient(180deg, transparent, rgba(255, 208, 36, 0.3), transparent);
  }

  /* ── Disclaimer — visible, not hidden ── */
  .tickets-disclaimer {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 640px;
    margin: 0 auto;
  }

  /* ── Floating geo ── */
  .tickets-geo {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .geo-diamond {
    position: absolute;
    background: rgba(255, 208, 36, 0.08);
    transform: rotate(45deg);
    animation: float-diamond-ticket 10s ease-in-out infinite;
  }
  .geo-diamond--1 { width: 120px; height: 120px; top: -40px; right: -30px; animation-delay: 0s; }
  .geo-diamond--2 { width: 80px; height: 80px; bottom: -20px; left: -20px; animation-delay: 4s; }
  .geo-diamond--3 { width: 50px; height: 50px; top: 40%; left: 8%; animation-delay: 7s; }

  @keyframes float-diamond-ticket {
    0%, 100% { transform: rotate(45deg) translateY(0); }
    50% { transform: rotate(45deg) translateY(-12px); }
  }

  /* ── Scroll reveal ── */
  .free-tickets {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .free-tickets.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .free-tickets {
      padding: 4rem 1rem;
    }

    .ticket-count-block {
      flex-direction: column;
      gap: 0.25rem;
    }

    .ticket-word {
      text-align: center;
    }

    .redeem-options {
      flex-direction: column;
      gap: 1.25rem;
      align-items: center;
    }

    .redeem-card {
      max-width: 100%;
      width: 100%;
    }

    .redeem-or {
      flex-direction: row;
      gap: 1rem;
    }

    .or-line {
      width: 40px;
      height: 1px;
    }

    .redeem-photo {
      height: 180px;
    }
  }
</style>
