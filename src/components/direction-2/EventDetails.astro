---
/**
 * Event Details — Date, time, location in spacious, clean cards.
 * Soft shadows, botanical accents on cards, generous whitespace.
 */
---

<section class="event-details scroll-reveal" id="details" aria-label="Event details">
  <div class="details-container">
    <p class="section-eyebrow">The Details</p>
    <h2 class="section-heading">
      Everything You Need to
      <span class="heading-accent"> Know</span>
    </h2>

    <div class="details-grid">
      <!-- Date Card -->
      <div class="detail-card detail-card--date">
        <div class="card-icon-wrap">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="1.5" stroke-linecap="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <h3 class="card-label">Date</h3>
        <p class="card-value">Saturday, March 28</p>
        <p class="card-note">Mark your calendar!</p>
        <!-- Leaf decoration -->
        <svg class="card-leaf" width="40" height="60" viewBox="0 0 40 60" fill="none" aria-hidden="true">
          <path d="M20 55 C20 55 5 30 20 5 C35 30 20 55 20 55Z" fill="var(--color-brand-primary)" opacity="0.08"/>
          <path d="M20 5 C20 5 20 30 20 55" stroke="var(--color-brand-primary)" stroke-width="0.75" opacity="0.15"/>
        </svg>
      </div>

      <!-- Time Card -->
      <div class="detail-card detail-card--time">
        <div class="card-icon-wrap">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-accent)" stroke-width="1.5" stroke-linecap="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h3 class="card-label">Time</h3>
        <p class="card-value">7:00 PM – 11:00 PM</p>
        <p class="card-note">Four hours of spring fun</p>
        <!-- Flower decoration -->
        <svg class="card-flower" width="50" height="50" viewBox="0 0 50 50" fill="none" aria-hidden="true">
          <circle cx="25" cy="25" r="6" fill="var(--color-brand-secondary)" opacity="0.15"/>
          <ellipse cx="25" cy="15" rx="5" ry="9" fill="var(--color-brand-accent)" opacity="0.08" transform="rotate(0 25 25)"/>
          <ellipse cx="25" cy="15" rx="5" ry="9" fill="var(--color-brand-accent)" opacity="0.08" transform="rotate(72 25 25)"/>
          <ellipse cx="25" cy="15" rx="5" ry="9" fill="var(--color-brand-accent)" opacity="0.08" transform="rotate(144 25 25)"/>
          <ellipse cx="25" cy="15" rx="5" ry="9" fill="var(--color-brand-accent)" opacity="0.08" transform="rotate(216 25 25)"/>
          <ellipse cx="25" cy="15" rx="5" ry="9" fill="var(--color-brand-accent)" opacity="0.08" transform="rotate(288 25 25)"/>
        </svg>
      </div>

      <!-- Location Card -->
      <div class="detail-card detail-card--location">
        <div class="card-icon-wrap">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="1.5" stroke-linecap="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <h3 class="card-label">Location</h3>
        <p class="card-value">Creative Labs Center</p>
        <p class="card-address">6180 Atlanta Highway<br/>Alpharetta, GA 30004</p>
        <!-- Leaf decoration -->
        <svg class="card-leaf card-leaf--right" width="35" height="55" viewBox="0 0 35 55" fill="none" aria-hidden="true">
          <path d="M17 52 C17 52 4 28 17 4 C30 28 17 52 17 52Z" fill="var(--color-brand-primary)" opacity="0.08"/>
          <path d="M17 4 C17 4 17 28 17 52" stroke="var(--color-brand-primary)" stroke-width="0.75" opacity="0.15"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .event-details {
    padding: clamp(4rem, 8vw, 7rem) 1.5rem;
    background: var(--color-brand-bg);
    position: relative;
  }

  .details-container {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  .section-eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-brand-primary);
    margin-bottom: 0.75rem;
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: var(--color-brand-text);
    line-height: 1.1;
    margin: 0 0 3rem 0;
  }

  .heading-accent {
    font-style: italic;
    color: var(--color-brand-primary);
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .details-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .detail-card {
    position: relative;
    background: white;
    border-radius: 20px;
    padding: 2.5rem 1.75rem 2rem;
    text-align: center;
    box-shadow: 0 4px 24px rgba(30, 58, 30, 0.05);
    border: 1px solid rgba(113, 175, 71, 0.08);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.4s ease;
  }

  .detail-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(113, 175, 71, 0.1);
  }

  @media (min-width: 640px) {
    .detail-card--time {
      transform: translateY(1.5rem);
    }
    .detail-card--time:hover {
      transform: translateY(calc(1.5rem - 4px));
    }
  }

  .card-icon-wrap {
    width: 56px;
    height: 56px;
    margin: 0 auto 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-brand-surface);
    border-radius: 16px;
  }

  .card-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-brand-muted);
    margin: 0 0 0.5rem 0;
  }

  .card-value {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-brand-text);
    margin: 0 0 0.35rem 0;
    line-height: 1.3;
  }

  .card-note,
  .card-address {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-brand-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Botanical card decorations */
  .card-leaf {
    position: absolute;
    bottom: -10px;
    left: -5px;
    transform: rotate(20deg);
    pointer-events: none;
  }

  .card-leaf--right {
    left: auto;
    right: -5px;
    transform: rotate(-15deg);
  }

  .card-flower {
    position: absolute;
    top: -8px;
    right: -8px;
    pointer-events: none;
  }

  /* Scroll reveal */
  .event-details {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .event-details.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
