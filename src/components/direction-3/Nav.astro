---
/**
 * Nav — Dark, slick scroll-responsive navbar. Blur backdrop on scroll.
 * Diamond motif as accent. Sharp, minimal, electric.
 */
---

<nav class="noche-nav" id="noche-nav">
  <div class="nav-inner">
    <div class="nav-brand">
      <div class="nav-logo-pill">
        <img src="/logos/creative-labs-logo.png" alt="Creative Labs Learning Center" class="nav-logo" />
      </div>
    </div>
    <div class="nav-event-tag">
      <span class="diamond-motif diamond-motif--sm" aria-hidden="true"></span>
      Spring Fiesta
      <span class="diamond-motif diamond-motif--sm" aria-hidden="true"></span>
    </div>
  </div>
</nav>

<style>
  @reference "../../styles/global.css";

  .noche-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(14, 14, 14, 0.6);
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    border-bottom: 1px solid transparent;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    padding: 1.1rem 1.5rem;
  }

  .noche-nav.scrolled {
    background: rgba(14, 14, 14, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom-color: rgba(255, 208, 36, 0.2);
    padding: 0.65rem 1.5rem;
    box-shadow: 0 4px 30px rgba(255, 208, 36, 0.08);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
  }

  .nav-logo-pill {
    background: white;
    border-radius: 8px;
    padding: 4px 12px;
    display: flex;
    align-items: center;
  }

  .nav-logo {
    height: 32px;
    width: auto;
    display: block;
  }

  .nav-event-tag {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand-primary);
    padding: 0.45rem 1.1rem;
    border: 1px solid rgba(255, 208, 36, 0.3);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    transition: all 0.3s ease;
  }

  .nav-event-tag:hover {
    border-color: var(--color-brand-primary);
    box-shadow: 0 0 16px rgba(255, 208, 36, 0.15);
  }

  /* Diamond motif — recurring geometric element */
  .diamond-motif {
    display: inline-block;
    background: var(--color-brand-primary);
  }
  .diamond-motif--sm {
    width: 6px;
    height: 6px;
    transform: rotate(45deg);
    animation: glow-pulse-diamond 3s ease-in-out infinite;
  }

  @keyframes glow-pulse-diamond {
    0%, 100% { opacity: 1; box-shadow: 0 0 4px rgba(255, 208, 36, 0.4); }
    50% { opacity: 0.6; box-shadow: 0 0 8px rgba(255, 208, 36, 0.8); }
  }

  @media (max-width: 480px) {
    .noche-nav {
      padding: 0.7rem 0.75rem;
    }
    .nav-logo {
      height: 24px;
    }
    .nav-event-tag {
      font-size: 0.6rem;
      padding: 0.35rem 0.7rem;
      gap: 0.35rem;
    }
    .diamond-motif--sm {
      width: 4px;
      height: 4px;
    }
  }
</style>

<script>
  const nav = document.getElementById('noche-nav');
  if (nav) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          if (window.scrollY > 60) {
            nav.classList.add('scrolled');
          } else {
            nav.classList.remove('scrolled');
          }
          ticking = false;
        });
        ticking = true;
      }
    });
  }
</script>
