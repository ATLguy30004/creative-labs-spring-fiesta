---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/direction-1/Nav.astro';
import Hero from '../components/direction-1/Hero.astro';
import EventDetails from '../components/direction-1/EventDetails.astro';
import FreeTickets from '../components/direction-1/FreeTickets.astro';
import FoodActivities from '../components/direction-1/FoodActivities.astro';
import LocationParking from '../components/direction-1/LocationParking.astro';
import PartnerBanner from '../components/direction-1/PartnerBanner.astro';
import Footer from '../components/direction-1/Footer.astro';
---

<Layout title="Fiesta Viva — Creative Labs Spring Fiesta" description="Join Creative Labs Center for the Spring Fiesta on Saturday, March 28! Food by Elote King Atlanta, mechanical bull rides, free popsicles for enrolled students, and a night of family fun in Alpharetta.">
  <style is:global>
    :root {
      --color-brand-primary:   #71AF47;
      --color-brand-secondary: #FFD024;
      --color-brand-accent:    #FF5C35;
      --color-brand-bg:        #FFF8F0;
      --color-brand-surface:   #FFF0DC;
      --color-brand-text:      #1A1A1A;
      --color-brand-muted:     #7A6A5A;
      --font-heading: 'Baloo 2 Variable', 'Baloo 2', Georgia, serif;
      --font-body:    'Nunito Variable', 'Nunito', system-ui, sans-serif;
    }

    /* Smooth scroll */
    html {
      scroll-behavior: smooth;
    }

    /* Selection color */
    ::selection {
      background: rgba(255, 92, 53, 0.2);
      color: var(--color-brand-text);
    }
  </style>

  <Nav />
  <Hero />
  <EventDetails />
  <FreeTickets />
  <FoodActivities />
  <LocationParking />
  <PartnerBanner />
  <Footer />

  <!-- Global scroll-reveal observer -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.15,
        rootMargin: '0px 0px -40px 0px',
      }
    );

    document.querySelectorAll('.scroll-reveal').forEach((el) => {
      observer.observe(el);
    });
  </script>
</Layout>
