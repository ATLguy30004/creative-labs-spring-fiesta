  "design_constraints": {
    "rule": "You do NOT design from scratch. You do NOT make component decisions independently.",
    "for_rebuild_sections": [
      "1. Search Starwind Pro for blocks that match the section's purpose",
      "2. List all viable options — block name, what it looks like, why it fits",
      "3. STOP. Report to Fahim and wait for his decision.",
      "4. Only after Fahim picks: install the block via `npx starwind@latest add @starwind-pro/[block-name]`",
      "5. Then swap brand tokens and copy ONLY — nothing else"
    ],
    "for_refine_sections": "Polish only — spacing, typography tuning, micro-details, hover states. No structural changes.",
    "allowed_changes_on_any_component": [
      "Brand colors (swap to palette values)",
      "Font families (swap to direction fonts)",
      "Text content and copy",
      "Image sources (use images from refine-context.json)"
    ],
    "never_do": [
      "Design any section from scratch",
      "Pick a Starwind block without Fahim's approval",
      "Change HTML structure of installed blocks",
      "Make layout or composition decisions independently"
    ],
    "if_no_starwind_block_exists": "Flag it clearly in the plan. Do not build. Fahim decides what happens next."
  }
}
