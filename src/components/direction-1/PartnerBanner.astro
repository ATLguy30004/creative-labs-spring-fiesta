---
/**
 * PartnerBanner — "In collaboration with Elote King Atlanta"
 * Prominent partnership callout section with yellow accent bg.
 */
---

<section class="partner-section" id="partner">
  <div class="partner-inner scroll-reveal" data-reveal="scale">
    <div class="partner-badge" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
        <circle cx="20" cy="20" r="18" fill="var(--color-brand-accent)" opacity="0.15"/>
        <path d="M10 22 C10 22 14 18 20 22 C26 26 30 22 30 22" stroke="var(--color-brand-accent)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <circle cx="13" cy="16" r="2" fill="var(--color-brand-primary)"/>
        <circle cx="27" cy="16" r="2" fill="var(--color-brand-primary)"/>
      </svg>
    </div>
    <p class="partner-label">In Collaboration With</p>
    <h3 class="partner-name">Elote King Atlanta</h3>
    <p class="partner-desc">
      Bringing the authentic flavors and fiesta energy to Creative Labs.
      Food, treats, and the legendary mechanical bull — all courtesy of Elote King!
    </p>

    <!-- Decorative confetti -->
    <span class="partner-confetti partner-confetti--1" aria-hidden="true"></span>
    <span class="partner-confetti partner-confetti--2" aria-hidden="true"></span>
    <span class="partner-confetti partner-confetti--3" aria-hidden="true"></span>
    <span class="partner-confetti partner-confetti--4" aria-hidden="true"></span>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .partner-section {
    position: relative;
    padding: 4rem 1.5rem;
    background: var(--color-brand-surface);
  }

  .partner-inner {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    background: white;
    border-radius: 32px;
    padding: 3rem 2.5rem;
    border: 3px solid var(--color-brand-secondary);
    box-shadow: 0 8px 40px rgba(255, 208, 36, 0.15);
    overflow: hidden;
  }

  .partner-badge {
    margin-bottom: 1rem;
  }

  .partner-label {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand-muted);
    margin-bottom: 0.5rem;
  }

  .partner-name {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: var(--color-brand-text);
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }

  .partner-desc {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-brand-muted);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto;
  }

  /* Decorative confetti dots inside the card */
  .partner-confetti {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .partner-confetti--1 { width: 12px; height: 12px; background: var(--color-brand-accent); top: 16px; left: 20px; opacity: 0.4; }
  .partner-confetti--2 { width: 8px; height: 8px; background: var(--color-brand-secondary); top: 24px; right: 32px; opacity: 0.5; }
  .partner-confetti--3 { width: 14px; height: 14px; background: var(--color-brand-primary); bottom: 20px; left: 40px; opacity: 0.3; transform: rotate(45deg); border-radius: 3px; }
  .partner-confetti--4 { width: 10px; height: 10px; background: var(--color-brand-accent); bottom: 28px; right: 24px; opacity: 0.35; }

  /* Scroll-reveal */
  .scroll-reveal {
    opacity: 0;
    transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }
  .scroll-reveal[data-reveal="scale"] { transform: scale(0.92); }
  .scroll-reveal.revealed {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>
