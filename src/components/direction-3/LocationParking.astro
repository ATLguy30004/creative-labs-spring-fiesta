---
/**
 * LocationParking — Sharp, clear location info.
 * Address prominent with parking note. Dark surface treatment.
 */
---

<section class="location-section scroll-reveal" aria-label="Location and parking">
  <div class="location-inner">
    <div class="section-header">
      <span class="diamond-motif" aria-hidden="true"></span>
      <h2 class="section-title">FIND US</h2>
      <span class="diamond-motif" aria-hidden="true"></span>
    </div>

    <div class="location-photo">
      <img
        src="/images/crowd_families_at_event.jpg"
        alt="Families gathered at Creative Labs Learning Center for the Spring Fiesta"
        class="location-photo-img"
        loading="lazy"
      />
    </div>

    <div class="location-grid">
      <div class="location-card">
        <div class="card-corner card-corner--tl" aria-hidden="true"></div>
        <div class="card-corner card-corner--br" aria-hidden="true"></div>
        <span class="location-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        <h3 class="location-name">Creative Labs Learning Center</h3>
        <p class="location-address">6180 Atlanta Highway<br>Alpharetta, GA 30004</p>
        <a href="https://maps.google.com/?q=6180+Atlanta+Highway+Alpharetta+GA+30004" target="_blank" rel="noopener noreferrer" class="location-link">
          Open in Maps
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      </div>

      <div class="parking-card">
        <div class="card-corner card-corner--tl" aria-hidden="true"></div>
        <div class="card-corner card-corner--br" aria-hidden="true"></div>
        <span class="parking-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><text x="12" y="16" text-anchor="middle" font-family="var(--font-heading)" font-size="12" font-weight="900" fill="var(--color-brand-secondary)" stroke="none">P</text></svg>
        </span>
        <h3 class="parking-title">Parking</h3>
        <p class="parking-text">Free parking available on-site. Come early for the best spots — the fiesta starts at 7 PM sharp.</p>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .location-section {
    position: relative;
    padding: 6rem 1.5rem;
    background: var(--color-brand-bg);
  }

  .location-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
    margin-bottom: 3rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-brand-text);
    letter-spacing: 0.08em;
    text-align: center;
  }

  .diamond-motif {
    width: 10px;
    height: 10px;
    background: var(--color-brand-primary);
    transform: rotate(45deg);
    flex-shrink: 0;
    box-shadow: 0 0 12px rgba(255, 208, 36, 0.4);
  }

  /* ── Event photo ── */
  .location-photo {
    margin-bottom: 2rem;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid rgba(255, 208, 36, 0.1);
  }

  .location-photo-img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  /* ── Grid ── */
  .location-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .location-card,
  .parking-card {
    position: relative;
    background: var(--color-brand-surface);
    border: 1px solid rgba(255, 208, 36, 0.1);
    padding: 2.5rem 2rem;
    text-align: center;
    transition: all 0.3s ease;
  }

  .location-card:hover,
  .parking-card:hover {
    border-color: rgba(255, 208, 36, 0.25);
    box-shadow: 0 0 30px rgba(255, 208, 36, 0.08);
  }

  .card-corner {
    position: absolute;
    width: 14px;
    height: 14px;
  }
  .card-corner--tl {
    top: 8px;
    left: 8px;
    border-top: 2px solid var(--color-brand-primary);
    border-left: 2px solid var(--color-brand-primary);
  }
  .card-corner--br {
    bottom: 8px;
    right: 8px;
    border-bottom: 2px solid var(--color-brand-primary);
    border-right: 2px solid var(--color-brand-primary);
  }

  .location-icon,
  .parking-icon {
    display: block;
    margin-bottom: 1.2rem;
  }

  .location-name {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1.5rem;
    color: var(--color-brand-text);
    margin: 0 0 0.8rem;
    letter-spacing: -0.01em;
  }

  .location-address {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-brand-muted);
    line-height: 1.6;
    margin: 0 0 1.5rem;
  }

  .location-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--color-brand-primary);
    text-decoration: none;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.5rem 1.2rem;
    border: 1px solid rgba(255, 208, 36, 0.3);
    transition: all 0.3s ease;
  }

  .location-link:hover {
    background: rgba(255, 208, 36, 0.1);
    border-color: var(--color-brand-primary);
    box-shadow: 0 0 16px rgba(255, 208, 36, 0.2);
  }

  .parking-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1.5rem;
    color: var(--color-brand-text);
    margin: 0 0 0.8rem;
  }

  .parking-text {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-brand-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Scroll reveal ── */
  .location-section {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .location-section.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .location-grid {
      grid-template-columns: 1fr;
    }

    .location-card,
    .parking-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
