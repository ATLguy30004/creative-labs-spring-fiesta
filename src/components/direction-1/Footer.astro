---
/**
 * Footer — Creative Labs branding, address, warm and simple.
 * Confetti diamond decorations, pill-shaped elements.
 */
---

<footer class="fiesta-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
        <rect width="44" height="44" rx="12" fill="var(--color-brand-primary)"/>
        <text x="22" y="29" text-anchor="middle" font-family="var(--font-heading)" font-size="20" font-weight="800" fill="white">CL</text>
      </svg>
      <div class="footer-brand-text">
        <span class="footer-name">Creative Labs Center</span>
        <span class="footer-tagline">Where every day is creative</span>
      </div>
    </div>

    <div class="footer-divider" aria-hidden="true">
      <span class="footer-diamond"></span>
      <span class="footer-diamond footer-diamond--yellow"></span>
      <span class="footer-diamond footer-diamond--green"></span>
    </div>

    <p class="footer-address">6180 Atlanta Highway, Alpharetta, GA 30004</p>
    <p class="footer-event">Spring Fiesta — Saturday, March 28 — 7:00 PM to 11:00 PM</p>

    <div class="footer-confetti" aria-hidden="true">
      <span class="fc fc--1"></span>
      <span class="fc fc--2"></span>
      <span class="fc fc--3"></span>
      <span class="fc fc--4"></span>
      <span class="fc fc--5"></span>
      <span class="fc fc--6"></span>
    </div>
  </div>
</footer>

<style>
  @reference "../../styles/global.css";

  .fiesta-footer {
    position: relative;
    padding: 4rem 1.5rem 3rem;
    background: var(--color-brand-text);
    color: white;
    text-align: center;
    overflow: hidden;
  }

  .footer-inner {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .footer-brand-text {
    text-align: left;
  }

  .footer-name {
    display: block;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
  }

  .footer-tagline {
    display: block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
  }

  .footer-divider {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .footer-diamond {
    width: 10px;
    height: 10px;
    background: var(--color-brand-accent);
    transform: rotate(45deg);
    border-radius: 2px;
    opacity: 0.6;
  }
  .footer-diamond--yellow { background: var(--color-brand-secondary); }
  .footer-diamond--green { background: var(--color-brand-primary); }

  .footer-address {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 0.4rem;
  }

  .footer-event {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.05em;
  }

  /* Background confetti */
  .footer-confetti {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  .fc {
    position: absolute;
    border-radius: 50%;
    opacity: 0.08;
  }
  .fc--1 { width: 80px; height: 80px; background: var(--color-brand-accent); top: -20px; left: 10%; }
  .fc--2 { width: 60px; height: 60px; background: var(--color-brand-secondary); bottom: -15px; right: 15%; }
  .fc--3 { width: 40px; height: 40px; background: var(--color-brand-primary); top: 50%; left: 5%; }
  .fc--4 { width: 30px; height: 30px; background: var(--color-brand-accent); top: 30%; right: 8%; }
  .fc--5 { width: 50px; height: 50px; background: var(--color-brand-secondary); bottom: 10%; left: 25%; }
  .fc--6 { width: 20px; height: 20px; background: var(--color-brand-primary); top: 15%; right: 30%; }
</style>
