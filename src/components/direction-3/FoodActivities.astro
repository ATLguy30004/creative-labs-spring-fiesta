---
/**
 * FoodActivities — Rebuilt using Starwind Pro Feature 15 (Bento Grid Spotlight).
 * Elote King gets the spotlight cell. Bull + Popsicles are supporting cards.
 */
import Feature15 from "@/components/starwind-pro/feature-15/Feature15.astro";
import IconFlame from "@tabler/icons/outline/flame.svg";
import IconIceCream from "@tabler/icons/outline/ice-cream.svg";
import communityEating from "@/assets/images/community_eating_together.jpg";
import riderAction from "@/assets/images/rider_action_zoom.jpg";
---

<div class="food-activities-wrap scroll-reveal">
  <Feature15
    tagline="Food & Activities"
    heading="Everything You Need for a Legendary Night"
    description="From authentic street food to mechanical bull rides — the Spring Fiesta has it all."
    features={[
      {
        type: "large",
        badge: "Food Partner",
        title: "Elote King Atlanta",
        description: "Authentic street food available for purchase all night. From elote to loaded corn cups — bring your appetite.",
        image: {
          src: communityEating,
          alt: "Community enjoying Elote King street food at the Spring Fiesta",
        },
      },
      {
        type: "small",
        icon: IconFlame,
        title: "Mechanical Bull",
        description: "Think you can hang on? Free ride with your student ticket or pay per ride.",
      },
      {
        type: "small",
        icon: IconIceCream,
        title: "Popsicles",
        description: "Cool down with a Popsicle from Elote King. Free with your student ticket.",
      },
      {
        type: "large",
        badge: "The Thrill",
        title: "Bull Ride Action",
        description: "The mechanical bull is the centerpiece of the night. Kids and adults — everyone gets a turn. It's the moment everyone talks about.",
        image: {
          src: riderAction,
          alt: "Rider on the mechanical bull at the Spring Fiesta",
        },
      },
      {
        type: "small",
        icon: IconFlame,
        title: "Live Energy",
        description: "Music, lights, and community vibes from 7 PM to 11 PM.",
      },
      {
        type: "small",
        icon: IconIceCream,
        title: "Family Fun",
        description: "A night for the whole family. Kids play, parents eat, everyone celebrates.",
      },
    ]}
  />
</div>

<style>
  @reference "../../styles/global.css";

  .food-activities-wrap {
    background: var(--color-brand-bg);
  }

  /* Subtle gradient on text-only bento cards (small type) */
  .food-activities-wrap :global(.spotlight:not(:has(img))) {
    background: linear-gradient(135deg, var(--color-brand-surface) 0%, rgba(255, 208, 36, 0.04) 100%);
  }

  /* Scroll reveal */
  .food-activities-wrap {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .food-activities-wrap.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
