---
/**
 * FreeTickets — VIP access section. Hot pink accent. Electric energy.
 * This is the KEY section — enrolled students get 2 FREE tickets.
 * Full-bleed hot pink moment against the dark background.
 */
---

<section class="free-tickets scroll-reveal" aria-label="Your free tickets">
  <!-- Geometric decorations -->
  <div class="tickets-geo" aria-hidden="true">
    <span class="geo-star-ticket geo-star-ticket--1"></span>
    <span class="geo-star-ticket geo-star-ticket--2"></span>
    <span class="geo-diamond-ticket geo-diamond-ticket--1"></span>
    <span class="geo-diamond-ticket geo-diamond-ticket--2"></span>
  </div>

  <div class="tickets-inner">
    <div class="vip-badge">
      <span class="diamond-motif-accent" aria-hidden="true"></span>
      Enrolled Student Exclusive
      <span class="diamond-motif-accent" aria-hidden="true"></span>
    </div>

    <h2 class="tickets-title">YOUR FREE<br>TICKETS</h2>

    <p class="tickets-hook">Each enrolled Creative Labs student receives</p>

    <div class="ticket-count-block">
      <span class="ticket-number">2</span>
      <span class="ticket-word">FREE TICKETS</span>
    </div>

    <div class="redeem-options">
      <div class="redeem-card">
        <div class="redeem-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/>
            <path d="M12 6v6l4 2"/>
            <path d="M8 18l-2 4M16 18l2 4"/>
          </svg>
        </div>
        <span class="redeem-label">Option A</span>
        <span class="redeem-value">Popsicle</span>
        <span class="redeem-detail">from Elote King</span>
      </div>

      <div class="redeem-or">
        <span>OR</span>
      </div>

      <div class="redeem-card">
        <div class="redeem-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22c-4.97 0-9-2.24-9-5v-2c0-2.76 4.03-5 9-5s9 2.24 9 5v2c0 2.76-4.03 5-9 5z"/>
            <path d="M12 10c-2.76 0-5-1.57-5-3.5S9.24 3 12 3s5 1.57 5 3.5S14.76 10 12 10z"/>
          </svg>
        </div>
        <span class="redeem-label">Option B</span>
        <span class="redeem-value">Mechanical Bull Ride</span>
        <span class="redeem-detail">at Elote King</span>
      </div>
    </div>

    <p class="tickets-fine">Tickets redeemable at the Elote King station during the event.</p>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .free-tickets {
    position: relative;
    padding: 6rem 1.5rem;
    background: var(--color-brand-accent);
    overflow: hidden;
  }

  .tickets-inner {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  /* ── VIP Badge ── */
  .vip-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    padding: 0.5rem 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    margin-bottom: 2rem;
  }

  .diamond-motif-accent {
    width: 6px;
    height: 6px;
    background: white;
    transform: rotate(45deg);
    display: inline-block;
  }

  /* ── Title ── */
  .tickets-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(3rem, 10vw, 6rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: white;
    margin: 0 0 1.5rem;
    text-shadow: 0 0 40px rgba(255, 255, 255, 0.2);
  }

  .tickets-hook {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  /* ── Giant ticket number ── */
  .ticket-count-block {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .ticket-number {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(5rem, 15vw, 9rem);
    color: white;
    line-height: 1;
    text-shadow: 0 0 50px rgba(255, 255, 255, 0.3);
    animation: number-glow 3s ease-in-out infinite alternate;
  }

  @keyframes number-glow {
    0% { text-shadow: 0 0 30px rgba(255, 255, 255, 0.2); }
    100% { text-shadow: 0 0 60px rgba(255, 255, 255, 0.4), 0 0 100px rgba(255, 255, 255, 0.15); }
  }

  .ticket-word {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(1.8rem, 5vw, 3rem);
    color: var(--color-brand-primary);
    letter-spacing: 0.05em;
    text-align: left;
    line-height: 1.1;
    text-shadow: 0 0 20px rgba(255, 208, 36, 0.4);
  }

  /* ── Redeem options ── */
  .redeem-options {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .redeem-card {
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 2rem 2rem;
    text-align: center;
    flex: 1;
    max-width: 260px;
    transition: all 0.3s ease;
    position: relative;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .redeem-card:hover {
    border-color: rgba(255, 255, 255, 0.4);
    box-shadow: 0 0 30px rgba(255, 255, 255, 0.1);
    transform: translateY(-4px);
  }

  .redeem-icon {
    color: var(--color-brand-primary);
    margin-bottom: 1rem;
  }

  .redeem-label {
    display: block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 0.5rem;
  }

  .redeem-value {
    display: block;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1.4rem;
    color: white;
    letter-spacing: -0.01em;
  }

  .redeem-detail {
    display: block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.4rem;
  }

  .redeem-or {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }

  .tickets-fine {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    font-style: italic;
  }

  /* ── Floating geo ── */
  .tickets-geo {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .geo-star-ticket {
    position: absolute;
    background: rgba(255, 255, 255, 0.15);
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
    animation: float-star-ticket 8s ease-in-out infinite;
  }
  .geo-star-ticket--1 { width: 24px; height: 24px; top: 10%; left: 5%; }
  .geo-star-ticket--2 { width: 18px; height: 18px; bottom: 15%; right: 8%; animation-delay: 3s; }

  .geo-diamond-ticket {
    position: absolute;
    background: rgba(255, 208, 36, 0.2);
    transform: rotate(45deg);
    animation: float-diamond-ticket 10s ease-in-out infinite;
  }
  .geo-diamond-ticket--1 { width: 14px; height: 14px; top: 25%; right: 12%; animation-delay: 1s; }
  .geo-diamond-ticket--2 { width: 10px; height: 10px; bottom: 30%; left: 10%; animation-delay: 5s; }

  @keyframes float-star-ticket {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(20deg); }
  }

  @keyframes float-diamond-ticket {
    0%, 100% { transform: rotate(45deg) translateY(0); }
    50% { transform: rotate(45deg) translateY(-10px); }
  }

  /* ── Scroll reveal ── */
  .free-tickets {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .free-tickets.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .free-tickets {
      padding: 5rem 1rem;
    }

    .ticket-count-block {
      flex-direction: column;
      gap: 0.5rem;
    }

    .ticket-word {
      text-align: center;
    }

    .redeem-options {
      flex-direction: column;
      gap: 1rem;
    }

    .redeem-card {
      max-width: 100%;
      width: 100%;
    }

    .redeem-or {
      margin: 0;
    }
  }
</style>
