---
/**
 * EventDetails — Concert-schedule grid with sharp column dividers.
 * Bold grid layout. Dark surface cards with corner marks.
 * Diamond motifs between items.
 */
---

<section class="event-details scroll-reveal" aria-label="Event details">
  <div class="details-inner">
    <div class="section-header">
      <span class="diamond-motif" aria-hidden="true"></span>
      <h2 class="section-title">THE DETAILS</h2>
      <span class="diamond-motif" aria-hidden="true"></span>
    </div>

    <div class="details-grid">
      <div class="detail-card">
        <div class="card-corner card-corner--tl" aria-hidden="true"></div>
        <div class="card-corner card-corner--br" aria-hidden="true"></div>
        <span class="detail-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </span>
        <span class="detail-label">Date</span>
        <span class="detail-value">Saturday, March 28</span>
      </div>

      <div class="grid-divider" aria-hidden="true"></div>

      <div class="detail-card">
        <div class="card-corner card-corner--tl" aria-hidden="true"></div>
        <div class="card-corner card-corner--br" aria-hidden="true"></div>
        <span class="detail-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </span>
        <span class="detail-label">Time</span>
        <span class="detail-value">7:00 PM – 11:00 PM</span>
      </div>

      <div class="grid-divider" aria-hidden="true"></div>

      <div class="detail-card">
        <div class="card-corner card-corner--tl" aria-hidden="true"></div>
        <div class="card-corner card-corner--br" aria-hidden="true"></div>
        <span class="detail-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        <span class="detail-label">Location</span>
        <span class="detail-value">Creative Labs Learning Center</span>
        <span class="detail-sub">6180 Atlanta Highway, Alpharetta, GA 30004</span>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../../styles/global.css";

  .event-details {
    position: relative;
    padding: 6rem 1.5rem;
    background: var(--color-brand-bg);
  }

  .details-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  /* ── Section header with diamonds ── */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
    margin-bottom: 3.5rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-brand-text);
    letter-spacing: 0.08em;
    text-align: center;
  }

  .diamond-motif {
    width: 10px;
    height: 10px;
    background: var(--color-brand-primary);
    transform: rotate(45deg);
    flex-shrink: 0;
    box-shadow: 0 0 12px rgba(255, 208, 36, 0.4);
  }

  /* ── Grid ── */
  .details-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: stretch;
    gap: 0;
  }

  .grid-divider {
    width: 1px;
    background: linear-gradient(180deg, transparent 10%, var(--color-brand-primary) 50%, transparent 90%);
    margin: 1rem 0;
  }

  .detail-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: var(--color-brand-surface);
    border: 1px solid rgba(255, 208, 36, 0.1);
    transition: all 0.3s ease;
  }

  .detail-card:hover {
    border-color: rgba(255, 208, 36, 0.3);
    box-shadow: 0 0 30px rgba(255, 208, 36, 0.08);
  }

  /* Geometric corner marks */
  .card-corner {
    position: absolute;
    width: 16px;
    height: 16px;
  }
  .card-corner--tl {
    top: 8px;
    left: 8px;
    border-top: 2px solid var(--color-brand-primary);
    border-left: 2px solid var(--color-brand-primary);
  }
  .card-corner--br {
    bottom: 8px;
    right: 8px;
    border-bottom: 2px solid var(--color-brand-primary);
    border-right: 2px solid var(--color-brand-primary);
  }

  .detail-icon {
    margin-bottom: 1.2rem;
    opacity: 0.9;
    transition: opacity 0.3s ease, filter 0.3s ease;
  }

  .detail-card:hover .detail-icon {
    opacity: 1;
    filter: drop-shadow(0 0 8px rgba(255, 208, 36, 0.5));
  }

  .detail-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand-muted);
    margin-bottom: 0.5rem;
  }

  .detail-value {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1.3rem;
    color: var(--color-brand-text);
    letter-spacing: -0.01em;
  }

  .detail-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-brand-muted);
    margin-top: 0.4rem;
    line-height: 1.5;
  }

  /* ── Scroll reveal ── */
  .event-details {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .event-details.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Mobile: stack vertically ── */
  @media (max-width: 768px) {
    .details-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .grid-divider {
      width: 100%;
      height: 1px;
      margin: 0;
      background: linear-gradient(90deg, transparent 10%, var(--color-brand-primary) 50%, transparent 90%);
    }

    .detail-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
